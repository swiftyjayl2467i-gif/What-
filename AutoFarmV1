	local function startReach()
		if reachConn then pcall(function() reachConn:Disconnect() end) end
		if hitConn   then pcall(function() hitConn:Disconnect()   end) end
		if hitConn2  then pcall(function() hitConn2:Disconnect()  end) end

		reachConn = RunService.Heartbeat:Connect(function()
			if not farmActive then return end
			local handle = findKatanaHandle()
			if not handle then return end
			pcall(function()
				handle.Size       = Vector3.new(REACH_RADIUS, REACH_RADIUS, REACH_RADIUS)
				handle.CanCollide = false
				handle.Massless   = true
			end)
		end)

		hitConn = RunService.Heartbeat:Connect(function()
			if not farmActive then return end
			local handle = findKatanaHandle()
			if not handle then return end
			for player, parts in pairs(cachedParts) do
				if player == LPlayer then continue end
				if not player.Character then continue end
				for _, part in ipairs(parts) do
					if part and part.Parent then
						pcall(function()
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
						end)
					end
				end
			end
		end)

		hitConn2 = RunService.RenderStepped:Connect(function()
			if not farmActive then return end
			local handle = findKatanaHandle()
			if not handle then return end
			for player, parts in pairs(cachedParts) do
				if player == LPlayer then continue end
				if not player.Character then continue end
				for _, part in ipairs(parts) do
					if part and part.Parent then
						pcall(function()
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
							firetouchinterest(part, handle, 0)
							firetouchinterest(part, handle, 1)
						end)
					end
				end
			end
		end)
	end

	local function stopReach()
		if reachConn then pcall(function() reachConn:Disconnect() end) reachConn = nil end
		if hitConn   then pcall(function() hitConn:Disconnect()   end) hitConn   = nil end
		if hitConn2  then pcall(function() hitConn2:Disconnect()  end) hitConn2  = nil end
	end

	local function stopAll()
		stopLocalOrbit()
		stopTrackingAll()
		stopHutboxLoop()
		stopReach()
	end

	local function shuffleTable(t)
		for i = #t, 2, -1 do
			local j = math.random(1, i)
			t[i], t[j] = t[j], t[i]
		end
	end

	local function tickVisitedServers()
		for id, count in pairs(visitedServers) do
			visitedServers[id] = count - 1
			if visitedServers[id] <= 0 then
				visitedServers[id] = nil
			end
		end
	end

	local function markServerVisited(jobId)
		visitedServers[jobId] = 3
	end

	local function isServerVisited(jobId)
		return visitedServers[jobId] ~= nil
	end

	local function fetchEligibleServers()
		local ok, result = pcall(function()
			return HttpService:JSONDecode(
				game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
			)
		end)
		if not ok or not result or not result.data then return {} end
		local eligible = {}
		for _, server in ipairs(result.data) do
			if server.id ~= game.JobId
				and not isServerVisited(server.id)
				and server.playing >= 3
				and server.playing <= 8 then
				table.insert(eligible, server)
			end
		end
		shuffleTable(eligible)
		return eligible
	end

	local function attemptTeleport(serverId)
		local ok = pcall(function()
			TeleportService:TeleportToPlaceInstance(game.PlaceId, serverId, LPlayer)
		end)
		return ok
	end

	local function attemptRandomTeleport()
		local ok = pcall(function()
			TeleportService:TeleportToRandomServer(game.PlaceId)
		end)
		return ok
	end

	local function queueScript()
		pcall(function()
			local src = safeRead(SCRIPT_PATH)
			if src and src ~= "" then
				queue_on_teleport(src)
			end
		end)
	end

	local function doHop(stepLbl)
		stopAll()
		farmActive = false
		tickVisitedServers()
		markServerVisited(game.JobId)
		writeActiveFlag()
		queueScript()

		local attempts = 0
		while attempts < HOP_MAX_RETRIES do
			attempts += 1
			if stepLbl then
				stepLbl.Text = "Hopping... (attempt " .. attempts .. ")"
			end
			local servers = fetchEligibleServers()
			if #servers > 0 then
				if attemptTeleport(servers[1].id) then
					task.wait(6)
				end
			else
				if attemptRandomTeleport() then
					task.wait(6)
				end
			end
			task.wait(HOP_RETRY_DELAY)
		end
	end

	local function triggerKickHop(stepLbl)
		farmActive = false
		stopAll()
		writeActiveFlag()
		queueScript()
		if stepLbl then stepLbl.Text = "Kicked — hopping..." end
		for _ = 1, 8 do
			local ok = pcall(function()
				TeleportService:TeleportToRandomServer(game.PlaceId)
			end)
			if ok then break end
			task.wait(0.25)
		end
	end

	local function startKickDetection(stepLbl)
		if kickConn then pcall(function() kickConn:Disconnect() end) kickConn = nil end

		local kickOk, kickResult = pcall(function()
			return LPlayer.Kicked:Connect(function()
				triggerKickHop(stepLbl)
			end)
		end)

		if kickOk and kickResult then
			kickConn = kickResult
		else
			local wasInGame = true
			kickConn = RunService.Heartbeat:Connect(function()
				local stillIn = false
				for _, p in ipairs(Players:GetPlayers()) do
					if p == LPlayer then
						stillIn = true
						break
					end
				end
				if wasInGame and not stillIn then
					wasInGame = false
					triggerKickHop(stepLbl)
				end
			end)
		end
	end

	local function runFarmCycle(stepLbl, cntLbl)
		if not farmActive then return end

		stepLbl.Text = "Acquiring EpicKatana..."
		giveKatana()
		task.wait(0.2)
		if not farmActive then return end

		local handle = findKatanaHandle()
		stepLbl.Text = "Inflating hitbox..."
		inflateHandle(handle)
		if not farmActive then return end

		stepLbl.Text = "Building part cache..."
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LPlayer then
				buildPartCache(p)
			end
		end
		if not farmActive then return end

		stepLbl.Text = "Starting reach system..."
		startReach()
		if not farmActive then stopReach() return end

		stepLbl.Text = "Starting map orbit..."
		startLocalOrbit()
		if not farmActive then stopAll() return end

		stepLbl.Text = "Auraing all players..."
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LPlayer then
				startTrackingPlayer(p)
			end
		end

		task.wait(1)
		if not farmActive then stopAll() return end

		stepLbl.Text = "Starting hutbox loop..."
		startHutboxLoop()

		local joinConn = Players.PlayerAdded:Connect(function(p)
			if not farmActive then return end
			task.wait(0.4)
			buildPartCache(p)
			startTrackingPlayer(p)
		end)

		local leaveConn = Players.PlayerRemoving:Connect(function(p)
			unregisterAured(p)
			clearPartCache(p)
			if trackedPlayers[p] then
				for _, conn in ipairs(trackedPlayers[p].conns) do
					pcall(function() conn:Disconnect() end)
				end
				trackedPlayers[p] = nil
			end
		end)

		local auraLoop = task.spawn(function()
			while farmActive do
				for _, p in ipairs(Players:GetPlayers()) do
					if not farmActive then break end
					if p ~= LPlayer and not stampingPlayers[p] then
						task.spawn(function()
							if isSeated(p) then return end
							local char = p.Character
							if not char then return end
							local hrp = char:FindFirstChild("HumanoidRootPart")
							if not hrp then return end
							makeNonCollideable(char)
							registerAured(p)
							stampAuraOnHRP(p, hrp)
						end)
					end
				end
				task.wait(1.5)
			end
		end)

		local startTime = tick()
		while farmActive and (tick() - startTime) < FARM_DURATION do
			cntLbl.Text = "Hop in " .. math.ceil(FARM_DURATION - (tick() - startTime)) .. "s"
			task.wait(0.5)
		end

		task.cancel(auraLoop)
		joinConn:Disconnect()
		leaveConn:Disconnect()

		if not farmActive then
			stopAll()
			stepLbl.Text = "Stopped"
			cntLbl.Text  = ""
			return
		end

		stopAll()
		cntLbl.Text = ""
		doHop(stepLbl)
	end

