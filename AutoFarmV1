	local function waitForNewModel(container, before, timeout)
		local beforeSet = {}
		for _, v in ipairs(before) do beforeSet[v] = true end
		local deadline = tick() + timeout
		while tick() < deadline do
			for _, v in ipairs(container:GetChildren()) do
				if not beforeSet[v] then return v end
			end
			task.wait()
		end
		return nil
	end

	local function getSpikePart(spikeModel)
		local retracting = spikeModel:FindFirstChild("Spike_Retracting", true)
		if not retracting then return nil end
		return retracting:FindFirstChild("Spikes")
	end

	local function isSeated(player)
		local char = player.Character
		if not char then return false end
		local hum = char:FindFirstChildOfClass("Humanoid")
		return hum ~= nil and hum.SeatPart ~= nil
	end

	local function makeNonCollideable(char)
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				pcall(function() part.CanCollide = false end)
			end
		end
	end

	local function buildPartCache(player)
		cachedParts[player] = nil
		local char = player.Character
		if not char then return end
		local parts = {}
		for _, desc in ipairs(char:GetDescendants()) do
			if desc:IsA("BasePart") then
				table.insert(parts, desc)
			end
		end
		if #parts > 0 then
			cachedParts[player] = parts
		end
	end

	local function clearPartCache(player)
		cachedParts[player] = nil
	end

	local function stampAuraOnHRP(player, hrp)
		if not LPlate or not ActiveParts or not hrp then return end
		if stampingPlayers[player] then return end
		stampingPlayers[player] = true

		task.spawn(function()
			local spikeModel, spikePart

			local before = ActiveParts:GetChildren()
			pcall(function()
				StampAsset:InvokeServer(
					41324904,
					LPlate.CFrame - Vector3.new(0, 100, 0),
					"{fca81e11-1ead-4817-afde-4dc29e72ea1b}",
					{LPlate},
					0
				)
			end)
			spikeModel = waitForNewModel(ActiveParts, before, 6)
			spikePart  = spikeModel and getSpikePart(spikeModel) or nil

			task.wait(0.1)

			if hrp and hrp.Parent then
				pcall(function()
					local targets = {hrp}
					if spikePart then table.insert(targets, spikePart) end
					StampAsset:InvokeServer(
						56451715,
						LPlate.CFrame - Vector3.new(0, 70, 0),
						"{aab5fc64-1831-41c1-b632-0978ffd5b311}",
						targets,
						0
					)
				end)
			end

			task.wait(0.35)

			if hrp and hrp.Parent then
				pcall(function()
					local targets = {hrp}
					if spikePart then table.insert(targets, spikePart) end
					StampAsset:InvokeServer(
						56451715,
						LPlate.CFrame - Vector3.new(0, 70, 0),
						"{aab5fc64-1831-41c1-b632-0978ffd5b311}",
						targets,
						0
					)
				end)
			end

			stampingPlayers[player] = nil
		end)
	end

	local function registerAured(player)
		auredPlayers[player] = true
	end

	local function unregisterAured(player)
		auredPlayers[player] = nil
		stampingPlayers[player] = nil
	end

	local function startTrackingPlayer(player)
		if player == LPlayer then return end
		if trackedPlayers[player] then return end
		local conns = {}

		local respawnConn = player.CharacterAdded:Connect(function(char)
			clearPartCache(player)
			unregisterAured(player)
			char:WaitForChild("HumanoidRootPart", 8)
			task.wait(0.15)
			if not farmActive then return end
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			buildPartCache(player)
			makeNonCollideable(char)
			registerAured(player)
			stampAuraOnHRP(player, hrp)
		end)

		table.insert(conns, respawnConn)
		trackedPlayers[player] = { conns = conns }

		task.spawn(function()
			if isSeated(player) then
				repeat task.wait(0.5) until not isSeated(player) or not farmActive
			end
			if not farmActive then return end
			local char = player.Character
			if not char then return end
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			buildPartCache(player)
			makeNonCollideable(char)
			registerAured(player)
			stampAuraOnHRP(player, hrp)
		end)
	end

	local function stopTrackingAll()
		for _, data in pairs(trackedPlayers) do
			for _, conn in ipairs(data.conns) do
				pcall(function() conn:Disconnect() end)
			end
		end
		trackedPlayers  = {}
		auredPlayers    = {}
		stampingPlayers = {}
		cachedParts     = {}
	end

	local function pickRandomHutboxPart()
		local hut = workspace:FindFirstChild("HutBox")
		if not hut then return nil end
		local parts = {}
		for _, inst in ipairs(hut:GetDescendants()) do
			if inst:IsA("BasePart") then
				table.insert(parts, inst)
			end
		end
		if #parts == 0 then return nil end
		return parts[math.random(1, #parts)]
	end

	local function prepareHutboxPart(part)
		if not part then return end
		pcall(function()
			part.Size         = Vector3.new(0.1, 0.1, 0.1)
			part.CanCollide   = false
			part.Anchored     = true
			part.Transparency = 1
			part.Massless     = true
		end)
	end

	local hutboxPart = nil

	local function startHutboxLoop()
		if hutboxConn then pcall(function() hutboxConn:Disconnect() end) end
		hutboxPart = pickRandomHutboxPart()
		if not hutboxPart then return end
		prepareHutboxPart(hutboxPart)
		local cycleIndex = 1
		hutboxConn = RunService.Heartbeat:Connect(function()
			if not farmActive then return end
			if not hutboxPart or not hutboxPart.Parent then
				hutboxPart = pickRandomHutboxPart()
				if hutboxPart then prepareHutboxPart(hutboxPart) end
				return
			end
			local affected = {}
			for p, _ in pairs(auredPlayers) do
				if p ~= LPlayer and p.Character then
					local hrp = p.Character:FindFirstChild("HumanoidRootPart")
					if hrp then table.insert(affected, hrp) end
				end
			end
			if #affected == 0 then return end
			if cycleIndex > #affected then cycleIndex = 1 end
			local target = affected[cycleIndex]
			cycleIndex += 1
			pcall(function() hutboxPart.CFrame = target.CFrame end)
		end)
	end

	local function stopHutboxLoop()
		if hutboxConn then
			pcall(function() hutboxConn:Disconnect() end)
			hutboxConn = nil
		end
		if hutboxPart then
			pcall(function() hutboxPart.CFrame = CFrame.new(0, -500, 0) end)
			hutboxPart = nil
		end
	end

	local function startLocalOrbit()
		if orbitConn then pcall(function() orbitConn:Disconnect() end) end
		local angle = 0
		orbitConn = RunService.Heartbeat:Connect(function(dt)
			if not farmActive then return end
			local char = LPlayer.Character
			if not char then return end
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			angle = angle + dt * 12
			pcall(function()
				hrp.CFrame = CFrame.new(
					math.cos(angle) * MAP_ORBIT_RADIUS,
					MAP_Y,
					math.sin(angle) * MAP_ORBIT_RADIUS
				)
			end)
		end)
	end

	local function stopLocalOrbit()
		if orbitConn then
			pcall(function() orbitConn:Disconnect() end)
