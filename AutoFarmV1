local function safeWrite(path, data)
	pcall(waxwritefile, path, data)
end

local function safeRead(path)
	local ok, result = pcall(waxreadfile, path)
	return ok and result or nil
end

local function writeActiveFlag()
	safeWrite(FLAG_PATH, "1")
end

local function readAndClearFlag()
	local val
	local deadline = tick() + 12
	while tick() < deadline do
		val = safeRead(FLAG_PATH)
		if val == "1" then break end
		task.wait(0.3)
	end
	safeWrite(FLAG_PATH, "0")
	return val == "1"
end

